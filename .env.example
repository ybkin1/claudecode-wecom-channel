# 企业微信机器人配置模板
# 复制此文件为 .env 并填入实际值

# 企业微信 AI 机器人配置
WECOM_BOT_ID=your_bot_id_here
WECOM_SECRET=your_secret_here

# Claude 配置（通过 claude -p --bare 共享认证，无需 API Key）
# CLAUDE_MODEL=sonnet  # 可选：指定模型
# WORKING_DIR=/path/to/knowledge/base  # 可选：指定工作目录

# 行为配置
# BOT_NAME=智算秘书
# GROUP_CHAT_ENABLED=true
# PRIVATE_CHAT_ENABLED=true
# STREAM_THROTTLE_MS=500
# HEARTBEAT_INTERVAL=30000

# 白名单（逗号分隔的用户 ID，留空则允许所有用户）
# ALLOWED_USERS=

# FileBroker 沙箱配置
# SANDBOX_DIR=/tmp/wecom-sandbox    # 沙箱根目录
# FILE_TTL_MS=300000                # 文件存活时间（ms），默认 5 分钟
# MAX_FILE_SIZE=10485760            # 接收文件最大字节数，默认 10 MB
# ALLOWED_FILE_EXTENSIONS=.md,.txt,.json,.csv,.xml,.yaml,.yml,.html,.css,.js,.ts,.py,.sh,.ps1,.log,.rst,.cfg,.ini,.toml
